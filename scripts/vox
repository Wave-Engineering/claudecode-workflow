#!/usr/bin/env bash
# vox — Text-to-speech announcements for Claude Code agents
#
# vox resolves a user-supplied *provider* (synthesis) and *player* (playback)
# via the hook pattern. Providers live at ~/.config/vox/provider; examples for
# common setups ship in scripts/vox-providers/. Run `vox --setup` to pick one.
#
# Usage:
#   vox "Hey BJ, deployment is done"
#   echo "Build failed" | vox
#   vox --voice Jade "Tests are passing"
#   vox --output /tmp/memo.wav "Voice memo for Discord"
#   vox --setup                             # interactive first-run setup
#   vox --setup --non-interactive --pick=silent
#   vox --help
#
# Provider contract (see scripts/vox-providers/README.md):
#   Input:  text as $1 (or stdin if $1 is empty)
#   Output: audio file written to $VOX_OUTPUT_FILE
#   Exit:   0 success, non-zero failure
#
# Resolution (first match wins):
#   Provider: $VOX_PROVIDER → ~/.config/vox/provider → bundled silent.sh
#   Player:   $VOX_PLAYER   → ~/.config/vox/player   → autodetect (afplay/paplay/aplay/ffplay)
#
# Environment passed through to the provider:
#   VOX_VOICE, VOX_MODEL, VOX_ENDPOINT, VOX_* (anything else prefixed VOX_)
#
# Special:
#   VOX_DISABLED=1   No audio, clean exit 0 (CI/headless/debug)
#
# Exit codes:
#   0  Success (or disabled)
#   1  Provider failed, player failed, or bad arguments

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
USER_CONFIG_DIR="${XDG_CONFIG_HOME:-$HOME/.config}/vox"
BUNDLED_PROVIDERS_DIR="$SCRIPT_DIR/vox-providers"

# --- Resolve provider ---------------------------------------------------------

resolve_provider() {
	local p=""
	if [[ -n "${VOX_PROVIDER:-}" ]]; then
		p="$VOX_PROVIDER"
		[[ -x "$p" ]] || {
			echo "vox: \$VOX_PROVIDER ($p) is not executable" >&2
			return 1
		}
		echo "$p"
		return 0
	fi
	if [[ -x "$USER_CONFIG_DIR/provider" ]]; then
		echo "$USER_CONFIG_DIR/provider"
		return 0
	fi
	if [[ -x "$BUNDLED_PROVIDERS_DIR/silent.sh" ]]; then
		echo "$BUNDLED_PROVIDERS_DIR/silent.sh"
		return 0
	fi
	echo "vox: no provider found (tried \$VOX_PROVIDER, $USER_CONFIG_DIR/provider, $BUNDLED_PROVIDERS_DIR/silent.sh)" >&2
	return 1
}

# --- Resolve player -----------------------------------------------------------

resolve_player() {
	if [[ -n "${VOX_PLAYER:-}" ]]; then
		echo "$VOX_PLAYER"
		return 0
	fi
	if [[ -x "$USER_CONFIG_DIR/player" ]]; then
		echo "$USER_CONFIG_DIR/player"
		return 0
	fi
	if [[ "$(uname -s)" == "Darwin" ]] && command -v afplay &>/dev/null; then
		echo "afplay"
		return 0
	fi
	if command -v paplay &>/dev/null; then
		echo "paplay"
		return 0
	fi
	if command -v aplay &>/dev/null; then
		echo "aplay -q"
		return 0
	fi
	if command -v ffplay &>/dev/null; then
		echo "ffplay -nodisp -autoexit -loglevel quiet"
		return 0
	fi
	echo ""
	return 0
}

# --- Usage / help -------------------------------------------------------------

usage() {
	cat <<-'USAGE'
		Usage: vox [OPTIONS] [MESSAGE...]

		Options:
		  --voice NAME       Voice name (exported as VOX_VOICE to the provider)
		  --bg               Background playback (don't wait for audio to finish)
		  --output, -o FILE  Write audio to FILE instead of playing
		  --setup [FLAGS]    Interactive first-run setup; picks a provider
		  -h, --help         Show this help

		Setup flags:
		  --non-interactive  Don't prompt; use --pick to select
		  --pick NAME        Provider name (silent|openai-endpoint|openai-qwen|piper-local|espeak|macos-say)

		Message can be passed as arguments or piped via stdin.

		Provider: see ~/.config/vox/provider; contract in scripts/vox-providers/README.md.
		Set VOX_DISABLED=1 to no-op cleanly (for CI / headless).
	USAGE
}

# --- Setup subcommand ---------------------------------------------------------

do_setup() {
	local non_interactive=false
	local pick=""
	while [[ $# -gt 0 ]]; do
		case "$1" in
		--non-interactive)
			non_interactive=true
			shift
			;;
		--pick)
			pick="${2:-}"
			shift 2
			;;
		--pick=*)
			pick="${1#--pick=}"
			shift
			;;
		*)
			echo "vox --setup: unknown flag '$1'" >&2
			return 1
			;;
		esac
	done

	if $non_interactive && [[ -z "$pick" ]]; then
		echo "vox --setup --non-interactive requires --pick NAME" >&2
		return 1
	fi

	if [[ ! -d "$BUNDLED_PROVIDERS_DIR" ]]; then
		echo "vox --setup: bundled providers dir not found at $BUNDLED_PROVIDERS_DIR" >&2
		return 1
	fi

	if ! $non_interactive; then
		echo "vox setup"
		echo ""
		echo "Available providers:"
		echo "  silent           — no-op (writes 0.1s silence; safe default)"
		echo "  openai-endpoint  — any OpenAI-compatible TTS API (VOX_ENDPOINT)"
		echo "  openai-qwen      — OpenAI-extended TTS (qwen3-tts, Chatterbox) — adds VOX_EMOTION"
		echo "  piper-local      — local piper binary (VOX_PIPER_MODEL)"
		echo "  espeak           — espeak-ng fallback (no network)"
		echo "  macos-say        — macOS say(1)"
		echo ""
		printf "Pick one: "
		read -r pick
	fi

	local src="$BUNDLED_PROVIDERS_DIR/${pick}.sh"
	if [[ ! -x "$src" ]]; then
		echo "vox --setup: no provider named '$pick' (looked for $src)" >&2
		return 1
	fi

	mkdir -p "$USER_CONFIG_DIR"
	ln -sf "$src" "$USER_CONFIG_DIR/provider"
	echo "vox: $USER_CONFIG_DIR/provider → $src"
}

# --- Parse args ---------------------------------------------------------------

VOICE="${VOX_VOICE:-}"
BACKGROUND=false
OUTPUT_FILE=""
args=()

while [[ $# -gt 0 ]]; do
	case "$1" in
	--voice)
		VOICE="${2:-}"
		[[ -z "$VOICE" ]] && {
			echo "Error: --voice requires a name" >&2
			exit 1
		}
		shift 2
		;;
	--bg)
		BACKGROUND=true
		shift
		;;
	--output | -o)
		OUTPUT_FILE="${2:-}"
		[[ -z "$OUTPUT_FILE" ]] && {
			echo "Error: --output requires a file path" >&2
			exit 1
		}
		shift 2
		;;
	--setup)
		shift
		do_setup "$@"
		exit $?
		;;
	-h | --help)
		usage
		exit 0
		;;
	--)
		shift
		args+=("$@")
		break
		;;
	-*)
		echo "Error: unknown option '$1'" >&2
		exit 1
		;;
	*)
		args+=("$1")
		shift
		;;
	esac
done

# --- VOX_DISABLED short-circuit -----------------------------------------------

if [[ "${VOX_DISABLED:-0}" == "1" ]]; then
	exit 0
fi

# --- Collect message text -----------------------------------------------------

if [[ ${#args[@]} -gt 0 ]]; then
	TEXT="${args[*]}"
elif [[ ! -t 0 ]]; then
	TEXT="$(cat)"
else
	echo "Error: no message provided. Pass as arguments or pipe via stdin." >&2
	exit 1
fi

if [[ -z "${TEXT//[$' \t\n\r']/}" ]]; then
	echo "Error: empty message" >&2
	exit 1
fi

# --- Resolve + invoke provider ------------------------------------------------

PROVIDER="$(resolve_provider)" || exit 1

if [[ -n "$OUTPUT_FILE" ]]; then
	audio_out="$OUTPUT_FILE"
else
	audio_out="$(mktemp --suffix=.wav)"
	trap 'rm -f "$audio_out"' EXIT
fi

VOX_OUTPUT_FILE="$audio_out" VOX_VOICE="$VOICE" "$PROVIDER" "$TEXT" || {
	echo "Error: provider '$PROVIDER' failed" >&2
	exit 1
}

# If --output was requested, we're done (audio is already at OUTPUT_FILE)
if [[ -n "$OUTPUT_FILE" ]]; then
	trap - EXIT
	exit 0
fi

# --- Wake noise preamble ------------------------------------------------------

# Prepend ~500ms of low-amplitude white noise to a WAV file. This wakes up
# Bluetooth audio sinks that sleep when idle, preventing the first syllable
# from being clipped.
prepend_wake_noise() {
	local wavfile="$1"
	python3 -c '
import wave, random, sys
with wave.open(sys.argv[1], "rb") as w:
    p = w.getparams()
    frames = w.readframes(w.getnframes())
sw = p.sampwidth
n = int(p.framerate * 0.5) * p.nchannels
max_amp = (1 << (8 * sw - 1)) - 1
scale = max(1, max_amp // 55)
bias = 128 if sw == 1 else 0
raw = b"".join(
    ((random.randint(-scale, scale) + bias) & ((1 << (8 * sw)) - 1))
    .to_bytes(sw, "little") for _ in range(n)
)
with wave.open(sys.argv[1], "wb") as w:
    w.setparams(p)
    w.writeframes(raw + frames)
' "$wavfile" 2>/dev/null || true
}

prepend_wake_noise "$audio_out"

# --- Resolve + invoke player --------------------------------------------------

PLAYER=$(resolve_player)
if [[ -z "$PLAYER" ]]; then
	echo "Error: no audio player found. Set \$VOX_PLAYER, symlink ~/.config/vox/player, or install aplay/paplay/afplay/ffplay." >&2
	exit 1
fi

if $BACKGROUND; then
	bgfile="$(mktemp --suffix=.wav)"
	cp "$audio_out" "$bgfile"
	(
		trap 'rm -f "$bgfile"' EXIT
		# shellcheck disable=SC2086
		timeout 60 $PLAYER "$bgfile" || true
	) &>/dev/null &
	disown
else
	# shellcheck disable=SC2086
	$PLAYER "$audio_out"
fi
