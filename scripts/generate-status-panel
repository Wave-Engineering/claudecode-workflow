</style>
</head>
<body>

<div class="header">
  <h1>{html.escape(phases_waves.get("project", "Project"))}</h1>
  <div class="meta">
    Wave Execution Status &middot;
    Current: <strong>{html.escape(current_wave)}</strong> &middot;
    Base: <code>{html.escape(phases_waves.get("base_branch", ""))}</code> &middot;
    Master Issue: #{html.escape(str(phases_waves.get("master_issue", "?")))}
  </div>

{action_block}

  <div class="stats-bar">
    <div class="stat">
      <div class="label">Issues</div>
      <div class="value">{stats["closed_issues"]}/{stats["total_issues"]}</div>
      <div class="sub">{stats["pct_issues"]}% complete</div>
      <div class="progress-bar"><div class="fill fill-fuchsia" style="width:{stats["pct_issues"]}%"></div></div>
    </div>
    <div class="stat">
      <div class="label">Waves</div>
      <div class="value">{stats["completed_waves"]}/{stats["total_waves"]}</div>
      <div class="sub">{stats["pct_waves"]}% complete</div>
      <div class="progress-bar"><div class="fill fill-cyan" style="width:{stats["pct_waves"]}%"></div></div>
    </div>
    <div class="stat">
      <div class="label">Phases</div>
      <div class="value">{len(phases_waves["phases"])}</div>
      <div class="sub">{sum(len(p["waves"]) for p in phases_waves["phases"])} total waves</div>
    </div>
    <div class="stat">
      <div class="label">Deferrals</div>
      <div class="value">{len(state.get("deferrals", []))}</div>
      <div class="sub">tracked items</div>
    </div>
  </div>
</div>

{phase_blocks}

{deferral_block}

<div class="footer">
  Generated {datetime.now(UTC).strftime("%Y-%m-%d %H:%M:%S")} UTC &middot;
  Last state update: {html.escape(last_updated)} &middot;
  <code>generate-status-panel</code>
</div>

</body>
</html>"""


def main() -> None:
    project_root = get_project_root()
    default_status_dir = project_root / ".claude" / "status"
    default_output = project_root / ".status-panel.html"

    parser = argparse.ArgumentParser(description="Generate wave execution status panel")
    parser.add_argument(
        "--output",
        default=str(default_output),
        help="Output HTML file path (default: <repo>/.status-panel.html)",
    )
    parser.add_argument(
        "--status-dir",
        default=str(default_status_dir),
        help="Directory containing status JSON files (default: <repo>/.claude/status)",
    )
    args = parser.parse_args()

    status_dir = Path(args.status_dir)

    for name in ("phases-waves.json", "flights.json", "state.json"):
        if not (status_dir / name).exists():
            print(f"Error: {status_dir / name} not found", file=__import__("sys").stderr)
            raise SystemExit(1)

    phases_waves = load_json(status_dir / "phases-waves.json")
    flights = load_json(status_dir / "flights.json")
    state = load_json(status_dir / "state.json")

    html_content = generate_html(phases_waves, flights, state)

    output_path = Path(args.output)
    output_path.write_text(html_content)
    print(f"Status panel generated: {output_path}")


if __name__ == "__main__":
    main()
