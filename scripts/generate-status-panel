#!/usr/bin/env python3
"""Generate a self-contained status panel HTML file from wave execution configs.

Reads three JSON config files from <repo>/.claude/status/ and produces a single
self-contained HTML file with inline CSS/JS, no external dependencies.

Discovers the project root via `git rev-parse --show-toplevel`, so it works
from any directory within a git repository.

Usage:
    generate-status-panel [--output .status-panel.html] [--status-dir .claude/status]
"""

from __future__ import annotations

import argparse
import html
import json
import subprocess
from datetime import UTC, datetime
from pathlib import Path


def get_project_root() -> Path:
    """Discover the git repository root from the current working directory."""
    try:
        result = subprocess.run(
            ["git", "rev-parse", "--show-toplevel"],
            capture_output=True,
            text=True,
            check=True,
        )
        return Path(result.stdout.strip())
    except (subprocess.CalledProcessError, FileNotFoundError):
        # Fall back to CWD if not in a git repo
        return Path.cwd()


def load_json(path: Path) -> dict:
    with open(path) as f:
        return json.load(f)


def status_icon(status: str) -> str:
    icons = {
        "completed": "&#x2705;",
        "in_progress": "&#x1F7E1;",
        "running": "&#x1F7E1;",
        "pending": "&#x23F3;",
        "failed": "&#x274C;",
        "closed": "&#x2705;",
        "open": "&#x23F3;",
        "blocked": "&#x1F6D1;",
    }
    return icons.get(status, "&#x2753;")


def status_class(status: str) -> str:
    classes = {
        "completed": "completed",
        "closed": "completed",
        "in_progress": "active",
        "running": "active",
        "pending": "pending",
        "open": "pending",
        "failed": "failed",
        "blocked": "blocked",
    }
    return classes.get(status, "pending")


def compute_stats(phases: list, state: dict) -> dict:
    total_issues = 0
    closed_issues = 0
    total_waves = 0
    completed_waves = 0

    for phase in phases:
        for wave in phase["waves"]:
            total_waves += 1
            wave_state = state.get("waves", {}).get(wave["id"], {})
            if wave_state.get("status") == "completed":
                completed_waves += 1
            for issue in wave["issues"]:
                total_issues += 1
                issue_state = state.get("issues", {}).get(str(issue["number"]), {})
                if issue_state.get("status") == "closed":
                    closed_issues += 1

    return {
        "total_issues": total_issues,
        "closed_issues": closed_issues,
        "total_waves": total_waves,
        "completed_waves": completed_waves,
        "pct_issues": round(100 * closed_issues / total_issues) if total_issues else 0,
        "pct_waves": round(100 * completed_waves / total_waves) if total_waves else 0,
    }


def render_phase_html(phase: dict, state: dict, flights: dict) -> str:
    phase_waves = phase["waves"]
    completed = sum(
        1
        for w in phase_waves
        if state.get("waves", {}).get(w["id"], {}).get("status") == "completed"
    )
    total = len(phase_waves)
    phase_status = "completed" if completed == total else ("active" if completed > 0 else "pending")

    lines = []
    lines.append(f'<div class="phase {phase_status}">')
    lines.append(f'  <div class="phase-header">')
    lines.append(
        f'    <h2>{html.escape(phase["name"])}'
        f' <span class="phase-progress">{completed}/{total} waves</span></h2>'
    )
    lines.append(f"  </div>")

    for wave in phase_waves:
        wave_id = wave["id"]
        wave_state = state.get("waves", {}).get(wave_id, {})
        ws = wave_state.get("status", "pending")
        mr_urls = wave_state.get("mr_urls", {})
        icon = status_icon(ws)
        cls = status_class(ws)

        lines.append(f'  <div class="wave {cls}">')
        lines.append(
            f'    <div class="wave-header">'
            f'{icon} <strong>{html.escape(wave["name"])}</strong>'
            f' <span class="badge {cls}">{ws}</span>'
            f"</div>"
        )

        wave_flights = flights.get("flights", {}).get(wave_id, [])
        if wave_flights:
            lines.append('    <div class="flights">')
            for i, flight in enumerate(wave_flights):
                flight_status = flight.get("status", "pending")
                fc = status_class(flight_status)
                lines.append(
                    f'      <span class="flight-badge {fc}">'
                    f'Flight {i + 1}: {", ".join(f"#{n}" for n in flight.get("issues", []))}'
                    f"</span>"
                )
            lines.append("    </div>")

        lines.append('    <table class="issue-table">')
        lines.append(
            "      <tr><th>#</th><th>Title</th><th>Deps</th><th>Status</th><th>MR</th></tr>"
        )

        for issue in wave["issues"]:
            num = issue["number"]
            issue_state = state.get("issues", {}).get(str(num), {})
            ist = issue_state.get("status", "pending")
            ic = status_class(ist)
            dep_str = ", ".join(f"#{d}" for d in issue.get("deps", [])) or "none"
            mr_str = mr_urls.get(str(num), "")

            lines.append(
                f"      <tr>"
                f'<td class="{ic}">#{num}</td>'
                f"<td>{html.escape(issue['title'])}</td>"
                f"<td>{html.escape(dep_str)}</td>"
                f"<td>{status_icon(ist)} {ist}</td>"
                f"<td>{html.escape(mr_str)}</td>"
                f"</tr>"
            )

        lines.append("    </table>")
        lines.append("  </div>")

    lines.append("</div>")
    return "\n".join(lines)


def render_deferrals(state: dict) -> str:
    deferrals = state.get("deferrals", [])
    if not deferrals:
        return ""

    lines = ['<div class="deferrals">', "  <h2>Deferred Items</h2>", '  <table class="issue-table">']
    lines.append("    <tr><th>Wave</th><th>Description</th><th>Risk</th></tr>")
    for d in deferrals:
        risk_cls = {"high": "failed", "medium": "active", "low": "pending"}.get(
            d.get("risk", "low"), "pending"
        )
        lines.append(
            f"    <tr>"
            f'<td>{html.escape(d.get("wave", ""))}</td>'
            f'<td>{html.escape(d.get("description", ""))}</td>'
            f'<td><span class="badge {risk_cls}">{html.escape(d.get("risk", ""))}</span></td>'
            f"</tr>"
        )
    lines.append("  </table>")
    lines.append("</div>")
    return "\n".join(lines)


def render_current_action(state: dict) -> str:
    action = state.get("current_action", {})
    if not action:
        return ""

    action_id = action.get("action", "idle")
    label = action.get("label", action_id)
    detail = action.get("detail", "")

    action_config = {
        "pre-flight": {"icon": "&#x1F50D;", "cls": "action-preflight", "verb": "Checking"},
        "planning": {"icon": "&#x1F9E0;", "cls": "action-planning", "verb": "Analyzing"},
        "in-flight": {"icon": "&#x1F680;", "cls": "action-inflight", "verb": "Executing"},
        "merging": {"icon": "&#x1F500;", "cls": "action-merging", "verb": "Merging"},
        "post-wave-review": {"icon": "&#x1F50E;", "cls": "action-review", "verb": "Reviewing"},
        "waiting-on-meatbag": {"icon": "&#x1F9B4;", "cls": "action-meatbag", "verb": ""},
        "idle": {"icon": "&#x1F4A4;", "cls": "action-idle", "verb": ""},
    }

    cfg = action_config.get(action_id, action_config["idle"])
    throb = ' throb' if action_id == "waiting-on-meatbag" else ""

    detail_html = f' <span class="action-detail">{html.escape(detail)}</span>' if detail else ""

    return (
        f'<div class="current-action {cfg["cls"]}{throb}">'
        f'  <span class="action-icon">{cfg["icon"]}</span>'
        f'  <span class="action-label">{html.escape(label)}</span>'
        f"  {detail_html}"
        f"</div>"
    )


def generate_html(phases_waves: dict, flights: dict, state: dict) -> str:
    stats = compute_stats(phases_waves["phases"], state)
    current_wave = state.get("current_wave", "unknown")
    last_updated = state.get("last_updated", "unknown")

    phase_blocks = "\n".join(
        render_phase_html(phase, state, flights) for phase in phases_waves["phases"]
    )

    deferral_block = render_deferrals(state)
    action_block = render_current_action(state)

    return f"""<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{html.escape(phases_waves.get("project", "Project"))} - Wave Execution Status</title>
<style>
:root {{
  --bg: #0a0a0f;
  --surface: #12121a;
  --surface-2: #1a1a26;
  --border: #2a2a3a;
  --text: #e0e0e8;
  --text-dim: #8888a0;
  --fuchsia: #ff00ff;
  --fuchsia-dim: #aa00aa;
  --cyan: #00ffff;
  --green: #00ff88;
  --yellow: #ffcc00;
  --red: #ff4444;
  --orange: #ff8800;
}}
* {{ margin: 0; padding: 0; box-sizing: border-box; }}
body {{
  background: var(--bg);
  color: var(--text);
  font-family: 'JetBrains Mono', 'Fira Code', 'Cascadia Code', monospace;
  font-size: 13px;
  line-height: 1.5;
  padding: 20px;
  max-width: 1200px;
  margin: 0 auto;
}}
h1 {{
  font-size: 1.8em;
  color: var(--fuchsia);
  text-shadow: 0 0 20px rgba(255, 0, 255, 0.3);
  margin-bottom: 4px;
}}
h2 {{
  font-size: 1.2em;
  color: var(--cyan);
  margin-bottom: 8px;
}}
.header {{
  border-bottom: 1px solid var(--border);
  padding-bottom: 16px;
  margin-bottom: 20px;
}}
.header .meta {{
  color: var(--text-dim);
  font-size: 0.9em;
}}
.stats-bar {{
  display: flex;
  gap: 24px;
  margin: 12px 0;
  flex-wrap: wrap;
}}
.stat {{
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 6px;
  padding: 10px 16px;
  min-width: 160px;
}}
.stat .label {{ color: var(--text-dim); font-size: 0.85em; }}
.stat .value {{ font-size: 1.6em; font-weight: bold; color: var(--fuchsia); }}
.stat .sub {{ color: var(--text-dim); font-size: 0.8em; }}
.progress-bar {{
  background: var(--surface-2);
  border-radius: 4px;
  height: 6px;
  margin-top: 6px;
  overflow: hidden;
}}
.progress-bar .fill {{
  height: 100%;
  border-radius: 4px;
  transition: width 0.3s;
}}
.fill-fuchsia {{ background: linear-gradient(90deg, var(--fuchsia-dim), var(--fuchsia)); }}
.fill-cyan {{ background: linear-gradient(90deg, #008888, var(--cyan)); }}

.phase {{
  background: var(--surface);
  border: 1px solid var(--border);
  border-radius: 8px;
  margin-bottom: 16px;
  overflow: hidden;
}}
.phase.completed {{ border-left: 3px solid var(--green); }}
.phase.active {{ border-left: 3px solid var(--fuchsia); }}
.phase.pending {{ border-left: 3px solid var(--text-dim); }}
.phase-header {{
  padding: 12px 16px;
  background: var(--surface-2);
  border-bottom: 1px solid var(--border);
}}
.phase-progress {{ color: var(--text-dim); font-size: 0.8em; font-weight: normal; }}

.wave {{
  margin: 8px 12px;
  padding: 8px 12px;
  border: 1px solid var(--border);
  border-radius: 6px;
  background: var(--bg);
}}
.wave:last-child {{ margin-bottom: 12px; }}
.wave.completed {{ border-color: var(--green); opacity: 0.8; }}
.wave.active {{ border-color: var(--fuchsia); box-shadow: 0 0 8px rgba(255, 0, 255, 0.15); }}
.wave.pending {{ border-color: var(--border); }}
.wave.failed {{ border-color: var(--red); }}
.wave-header {{ margin-bottom: 6px; }}

.badge {{
  display: inline-block;
  padding: 1px 8px;
  border-radius: 10px;
  font-size: 0.8em;
  font-weight: bold;
  text-transform: uppercase;
}}
.badge.completed {{ background: rgba(0, 255, 136, 0.15); color: var(--green); }}
.badge.active {{ background: rgba(255, 0, 255, 0.15); color: var(--fuchsia); }}
.badge.pending {{ background: rgba(136, 136, 160, 0.15); color: var(--text-dim); }}
.badge.failed {{ background: rgba(255, 68, 68, 0.15); color: var(--red); }}
.badge.blocked {{ background: rgba(255, 136, 0, 0.15); color: var(--orange); }}

.flights {{
  margin: 4px 0 6px;
  display: flex;
  gap: 8px;
  flex-wrap: wrap;
}}
.flight-badge {{
  display: inline-block;
  padding: 2px 8px;
  border-radius: 4px;
  font-size: 0.8em;
  background: var(--surface-2);
  border: 1px solid var(--border);
}}

.issue-table {{
  width: 100%;
  border-collapse: collapse;
  font-size: 0.9em;
}}
.issue-table th {{
  text-align: left;
  padding: 4px 8px;
  border-bottom: 1px solid var(--border);
  color: var(--text-dim);
  font-weight: normal;
  font-size: 0.85em;
}}
.issue-table td {{
  padding: 4px 8px;
  border-bottom: 1px solid rgba(42, 42, 58, 0.5);
}}
.issue-table td.completed {{ color: var(--green); }}
.issue-table td.active {{ color: var(--fuchsia); }}
.issue-table td.pending {{ color: var(--text-dim); }}
.issue-table td.failed {{ color: var(--red); }}

@keyframes throb {{
  0%, 100% {{ opacity: 1;    transform: scale(1); }}
  50%       {{ opacity: 0.35; transform: scale(0.94); }}
}}
.current-action {{
  display: flex;
  align-items: center;
  gap: 10px;
  padding: 12px 16px;
  border-radius: 8px;
  margin-bottom: 16px;
  font-size: 1.1em;
  font-weight: bold;
  border: 1px solid var(--border);
  background: var(--surface);
}}
.current-action .action-icon {{ font-size: 1.4em; }}
.current-action .action-detail {{
  font-weight: normal;
  font-size: 0.85em;
  color: var(--text-dim);
  margin-left: 4px;
}}
.action-preflight {{ border-color: var(--cyan); color: var(--cyan); }}
.action-planning {{ border-color: var(--yellow); color: var(--yellow); }}
.action-inflight {{
  border-color: var(--fuchsia);
  color: var(--fuchsia);
  box-shadow: 0 0 12px rgba(255, 0, 255, 0.2);
}}
.action-merging {{ border-color: var(--green); color: var(--green); }}
.action-review {{ border-color: var(--orange); color: var(--orange); }}
.action-idle {{ border-color: var(--border); color: var(--text-dim); }}
.action-meatbag {{
  border-color: var(--fuchsia);
