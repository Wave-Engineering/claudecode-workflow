  box-shadow: 0 0 20px rgba(255, 0, 255, 0.15);
}}
.current-action.throb {{
  animation: throb 2.5s ease-in-out infinite;
}}

.deferrals {{
  background: var(--surface);
  border: 1px solid var(--border);
